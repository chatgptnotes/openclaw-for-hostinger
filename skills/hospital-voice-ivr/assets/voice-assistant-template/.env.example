# Hope Hospital Voice Assistant Configuration

# ===== IVR Provider =====
# Choose: twilio, exotel, or custom
IVR_PROVIDER=exotel

# Twilio (if using)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# Exotel (if using - popular in India)
EXOTEL_SID=your_exotel_sid
EXOTEL_TOKEN=your_exotel_token
EXOTEL_SUBDOMAIN=your_subdomain

# ===== Speech-to-Text (ASR) =====
# Choose: google, azure, deepgram, sarvam
STT_PROVIDER=sarvam

# Google Cloud Speech (if using)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Azure Speech (if using)
AZURE_SPEECH_KEY=your_key
AZURE_SPEECH_REGION=centralindia

# Deepgram (if using)
DEEPGRAM_API_KEY=your_key

# Sarvam AI (Indian languages specialist - RECOMMENDED)
SARVAM_API_KEY=your_sarvam_key

# ===== Text-to-Speech =====
# Choose: elevenlabs, azure, google, sarvam
TTS_PROVIDER=sarvam

# ElevenLabs (if using)
ELEVENLABS_API_KEY=your_key
ELEVENLABS_VOICE_ID=your_indian_voice_id

# Sarvam AI TTS (Indian voices - RECOMMENDED)
SARVAM_TTS_VOICE=meera  # Options: meera, pavithra, maitreyi, arvind, karthik

# ===== Language Settings =====
DEFAULT_LANGUAGE=hi  # hi = Hindi, en = English
SUPPORTED_LANGUAGES=hi,en
AUTO_DETECT_LANGUAGE=true

# ===== Hospital Settings =====
HOSPITAL_NAME=Hope Hospital
HOSPITAL_PHONE=+917028083083
EMERGENCY_NUMBER=+917028083083
OPD_TIMINGS=9:00 AM - 8:00 PM
EMERGENCY_TIMINGS=24x7

# ===== Server =====
PORT=3000
NODE_ENV=production
